      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <OriginalItemSpec>$([System.IO.Path]::GetFullPath($(MSBuildThisFileDirectory)..\staticwebassets\WorkPage.html))</OriginalItemSpec>
    </StaticWebAsset>
  </ItemGroup>
</Project>